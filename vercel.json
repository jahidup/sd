<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Student Dashboard – Sankalp Digital Pathshala</title>
  <link rel="stylesheet" href="assets/css/style.css">
</head>
<body>
  <div class="dashboard-layout">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <button class="close-sidebar" onclick="document.getElementById('sidebar').classList.remove('active')">&times;</button>
      <div class="sidebar-brand"><a href="index.html">🎓 SDP</a></div>
      <ul class="sidebar-nav">
        <li><a href="#" class="sidebar-link active" data-view="dashboard">📊 Dashboard</a></li>
        <li><a href="#" class="sidebar-link" data-view="myCourses">📚 My Courses</a></li>
        <li><a href="#" class="sidebar-link" data-view="tests">📝 Tests</a></li>
        <li><a href="#" class="sidebar-link" data-view="practice">📋 Practice</a></li>
        <li><a href="#" class="sidebar-link" data-view="messages">💬 Messages</a></li>
        <li><a href="#" class="sidebar-link" data-view="community">🌐 Community</a></li>
        <li><a href="#" class="sidebar-link" data-view="notifications">🔔 Notifications</a></li>
        <li><a href="#" class="sidebar-link" data-view="progress">📈 Progress</a></li>
        <li><a href="#" class="sidebar-link" data-view="performance">🏆 Report</a></li>
        <li><a href="#" class="sidebar-link" data-view="askDoubt">❓ Ask Doubt</a></li>
        <li><a href="#" class="sidebar-link" data-view="myDoubts">💬 My Doubts</a></li>
        <li><a href="#" class="sidebar-link" data-view="sankalpSathi">🤖 Sankalp Sathi</a></li>
        <li><a href="#" class="sidebar-link logout-link" onclick="handleLogout()">🚪 Logout</a></li>
      </ul>
    </aside>

    <!-- Main Content -->
    <main class="dashboard-main">
      <header class="dashboard-topbar">
        <button class="sidebar-toggle-btn" id="sidebarToggle">☰</button>
        <h2>Dashboard</h2>
        <div class="topbar-user" id="topbarUser"></div>
      </header>
      <div class="dashboard-content" id="dashboardContent">
        <div class="loading-spinner">Loading dashboard...</div>
      </div>
    </main>
  </div>

  <div class="toast-container" id="toastContainer"></div>
  <script src="assets/js/app.js"></script>
</body>
</html>
